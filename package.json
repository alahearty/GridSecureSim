{
  "name": "energy-trading-protection-system",
  "version": "2.0.0",
  "description": "Real-time smart contract protection system for blockchain-based energy trading",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "frontend": "cd frontend && npm start",
    "build": "cd frontend && npm run build",
    "test": "jest",
    "test:backend": "jest test/server.test.js --verbose",
    "test:contract": "npx hardhat test",
    "deploy:contract": "npx hardhat run scripts/deploy.js --network localhost",
    "compile": "npx hardhat compile",
    "simulate": "node simulation/engine.js"
  },
  "dependencies": {
    "axios": "^1.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "ethers": "^6.14.3",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "node-cron": "^4.0.7",
    "pg": "^8.16.0",
    "sequelize": "^6.37.7",
    "socket.io": "^4.8.3",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.3.0",
    "@types/node": "^22.15.21",
    "hardhat": "^2.23.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "sqlite3": "^6.0.1",
    "supertest": "^7.2.2"
  },
  "keywords": [
    "blockchain",
    "energy-trading",
    "smart-contract",
    "security",
    "real-time"
  ],
  "author": "Energy Trading Protection System",
  "license": "MIT"
}
